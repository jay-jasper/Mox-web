---
import '@/styles/global.css';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import ThemePanel from '@/components/ThemePanel.astro';
import { withBase } from '@/lib/url';
import type { Locale } from '@/i18n';
const { title, description } = Astro.props as { title: string; description?: string };
// Locale + canonical/hreflang computed RELATIVE TO THE BASE PATH (e.g. "/Mox-web/"),
// so they're correct both locally and on a GitHub Pages project page.
const base = import.meta.env.BASE_URL;
const rel = Astro.url.pathname.slice(base.length).replace(/^\//, ''); // '' | 'en' | 'timeline' | 'en/timeline' | 'docs'
const isEn = rel === 'en' || rel.startsWith('en/');
const locale: Locale = isEn ? 'en' : 'zh';
const zhRel = isEn ? rel.replace(/^en\/?/, '') : rel;
const enRel = isEn ? rel : 'en' + (rel ? '/' + rel : '');
const canonical = new URL(base + rel, Astro.site).href;
const zhHref = new URL(base + zhRel, Astro.site).href;
const enHref = new URL(base + enRel, Astro.site).href;
---
<!doctype html>
<html lang={locale === 'en' ? 'en' : 'zh'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="zh" href={zhHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={zhHref} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta name="theme-color" content="#f4eee2" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Dancing+Script:wght@600;700&family=Liu+Jian+Mao+Cao&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="site-bg"></div>
    <canvas id="site-fx" class="site-fx"></canvas>
    <Nav locale={locale} />
    <ThemePanel locale={locale} />
    <main><slot /></main>
    <Footer locale={locale} />
    <script>
      // Scroll-reveal: fade/slide elements in as they enter the viewport, once.
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        }
      }, { threshold: 0.15 });
      document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
    </script>
    <script>
      import { initTheme } from '@/theme/control';
      initTheme();
    </script>
  </body>
</html>
