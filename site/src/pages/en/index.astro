---
import Base from '@/layouts/Base.astro';
import HeroHandwriting from '@/components/HeroHandwriting.astro';
---
<Base title="Mox — Write beautifully, think clearly" description="A native macOS WYSIWYG Markdown editor with 20 themes and live effects">
  <HeroHandwriting locale="en" />
  <section id="features" class="container section"><h2>Features</h2><p class="muted">(feature narrative — M4)</p></section>
  <section id="themes" class="container section"><h2>Themes</h2><p class="muted">(theme gallery — M3)</p></section>
</Base>
<style>
  .section { padding: 48px 24px; }
  .muted { color: var(--muted); }
</style>
