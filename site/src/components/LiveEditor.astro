---
import type { Locale } from '@/i18n';
const { locale } = Astro.props as { locale: Locale };
const isEn = locale === 'en';
const modes = isEn
  ? [['wysiwyg', 'Rich Text'], ['source', 'Source'], ['split', 'Split']]
  : [['wysiwyg', '富文本'], ['source', '源码'], ['split', '分屏']];
const initial = isEn
  ? `# Hello, Mox\n\n**Rich-text** Markdown writing — markers hide as you type.\n\n- Math, diagrams, mind-maps\n- Knowledge graph & quick notes\n- One-click export\n\n> Write the first line; the rest will follow.\n\n\`mox()\``
  : `# 你好，Mox\n\n**富文本**式的 Markdown 写作，标记随光标隐去。\n\n- 数学、图表、思维导图\n- 知识图谱与速记\n- 一键导出多种格式\n\n> 写下第一行，余下的自会跟来。\n\n\`mox()\``;
---
<div id="live-editor" class="le" data-initial={initial}>
  <div class="le-bar">
    <div class="dots"><span></span><span></span><span></span></div>
    <div class="seg">
      {modes.map(([m, label], i) => (
        <button class:list={["m", { on: i === 0 }]} data-mode={m}>{label}</button>
      ))}
    </div>
  </div>
  <div class="le-body" data-mode="wysiwyg">
    <div class="pane wysiwyg prose"></div>
    <pre class="pane source"></pre>
    <div class="pane split">
      <pre class="split-src"></pre>
      <div class="split-prev prose"></div>
    </div>
  </div>
</div>

<style is:global>
  /* #live-editor scope; is:global because rendered markdown is injected via innerHTML. */
  #live-editor.le { border-radius: 14px; overflow: hidden; background: var(--card);
    border: 1px solid var(--hairline); box-shadow: 0 30px 70px rgba(60,45,30,.16); display: flex; flex-direction: column; height: 460px; }
  #live-editor .le-bar { display: flex; align-items: center; gap: 14px; padding: 11px 14px;
    border-bottom: 1px solid var(--hairline); background: color-mix(in srgb, var(--fg) 3%, transparent); }
  #live-editor .dots { display: flex; gap: 7px; }
  #live-editor .dots span { width: 11px; height: 11px; border-radius: 50%; }
  #live-editor .dots span:nth-child(1) { background: #ff5f57; }
  #live-editor .dots span:nth-child(2) { background: #febc2e; }
  #live-editor .dots span:nth-child(3) { background: #28c840; }
  #live-editor .seg { margin-left: auto; display: inline-flex; background: color-mix(in srgb, var(--fg) 8%, transparent); border-radius: 9px; padding: 3px; }
  #live-editor .seg .m { border: none; background: none; cursor: pointer; padding: 5px 12px; border-radius: 7px; font: inherit; font-size: 13px; font-weight: 600; color: var(--muted); }
  #live-editor .seg .m.on { background: var(--card); color: var(--fg); box-shadow: 0 1px 3px rgba(0,0,0,.1); }

  #live-editor .le-body { position: relative; flex: 1; min-height: 0; }
  #live-editor .pane { display: none; height: 100%; width: 100%; margin: 0; }
  #live-editor .le-body[data-mode="wysiwyg"] .wysiwyg { display: block; }
  #live-editor .le-body[data-mode="source"] .source { display: block; }
  #live-editor .le-body[data-mode="split"] .split { display: flex; }

  #live-editor .wysiwyg, #live-editor .split-prev { overflow: auto; padding: 22px 26px; }
  #live-editor pre.source, #live-editor pre.split-src { overflow: auto; white-space: pre-wrap; word-break: break-word;
    color: var(--text); font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 14px; line-height: 1.7; padding: 22px 26px; }
  #live-editor .split { gap: 0; }
  #live-editor .split .split-src { flex: 1; border-right: 1px solid var(--hairline); }
  #live-editor .split .split-prev { flex: 1; }

  /* blinking type cursor */
  #live-editor .cursor { display: inline-block; width: 2px; height: 1.05em; vertical-align: text-bottom;
    background: var(--accent); margin-left: 1px; animation: le-blink 1s step-end infinite; }
  @keyframes le-blink { 50% { opacity: 0; } }

  /* prose styling for rendered markdown */
  #live-editor .prose { color: var(--text); }
  #live-editor .prose h1 { font-size: 24px; margin: 0 0 12px; }
  #live-editor .prose p { margin: 10px 0; }
  #live-editor .prose ul { margin: 10px 0; padding-left: 20px; }
  #live-editor .prose li { margin: 4px 0; }
  #live-editor .prose strong { color: var(--fg); }
  #live-editor .prose blockquote { margin: 12px 0; padding: 6px 14px; border-left: 3px solid var(--accent); color: var(--muted); }
  #live-editor .prose code { font-family: ui-monospace, monospace; font-size: .9em; background: color-mix(in srgb, var(--fg) 8%, transparent); padding: 2px 6px; border-radius: 5px; }
  #live-editor .prose pre { background: color-mix(in srgb, var(--fg) 6%, transparent); padding: 14px; border-radius: 10px; overflow: auto; }
  #live-editor .prose pre code { background: none; padding: 0; }
</style>

<script>
  import MarkdownIt from 'markdown-it';

  const root = document.getElementById('live-editor');
  if (root) {
    const md = new MarkdownIt({ html: false, linkify: true, breaks: false });
    const body = root.querySelector('.le-body') as HTMLElement;
    const wys = root.querySelector('.wysiwyg') as HTMLElement;
    const src = root.querySelector('.source') as HTMLElement;
    const splitSrc = root.querySelector('.split-src') as HTMLElement;
    const splitPrev = root.querySelector('.split-prev') as HTMLElement;
    const target = root.dataset.initial || '';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let mode = 'wysiwyg';
    let shown = 0;
    const CURSOR = '<span class="cursor"></span>';

    function escapeHtml(s: string) {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }
    function render() {
      const txt = target.slice(0, shown);
      const typing = shown < target.length;
      if (mode === 'wysiwyg') {
        wys.innerHTML = md.render(txt) + (typing ? CURSOR : '');
      } else if (mode === 'source') {
        src.innerHTML = escapeHtml(txt) + (typing ? CURSOR : '');
      } else {
        splitSrc.innerHTML = escapeHtml(txt) + (typing ? CURSOR : '');
        splitPrev.innerHTML = md.render(txt);
      }
    }
    function setMode(m: string) {
      mode = m;
      body.dataset.mode = m;
      root.querySelectorAll('.seg .m').forEach((b) => b.classList.toggle('on', (b as HTMLElement).dataset.mode === m));
      render();
    }
    root.querySelectorAll<HTMLButtonElement>('.seg .m').forEach((b) =>
      b.addEventListener('click', () => setMode(b.dataset.mode!)));

    // Read-only typewriter — types itself out once the editor scrolls into view.
    function type() {
      if (shown >= target.length) { render(); return; }
      shown++;
      render();
      const ch = target[shown - 1];
      // pause a little longer after newlines / punctuation for a natural rhythm
      const delay = ch === '\n' ? 170 : /[，。、,.\s]/.test(ch) ? 90 : 38 + Math.random() * 34;
      window.setTimeout(type, delay);
    }

    if (reduce) { shown = target.length; render(); }
    else {
      render();
      const io = new IntersectionObserver((es) => {
        for (const e of es) if (e.isIntersecting) { io.disconnect(); window.setTimeout(type, 500); }
      }, { threshold: 0.4 });
      io.observe(root);
    }
  }
</script>
