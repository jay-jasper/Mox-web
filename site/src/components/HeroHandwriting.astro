---
import { t, type Locale } from '@/i18n';
import LiveEditor from '@/components/LiveEditor.astro';
const { locale } = Astro.props as { locale: Locale };
const isEn = locale === 'en';
const zh = '专注写作 优雅表达';
const sub = isEn
  ? 'A quiet writing space for macOS. WYSIWYG and natively fast — just you and the words.'
  : '一个安静的 macOS 写作空间。所见即所得，原生流畅，让你只与文字相处。';
---
<section id="hero" class="hero">
  <div class="container grid">
    <div class="lead">
      <h1 class="hand"><span class="zh">{zh}</span></h1>
      <p class="sub">{sub}</p>
      <div class="cta-row">
        <a class="btn" href="#download">{t(locale, 'nav.download')}</a>
      </div>
    </div>
    <div class="editor-wrap">
      <LiveEditor locale={locale} />
    </div>
  </div>
  <a class="scroll-cue" href="#features" aria-label={isEn ? 'Scroll down' : '向下'}>
    <span>{isEn ? 'Scroll' : '向下'}</span>
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6"/></svg>
  </a>
</section>

<style>
  .hero { position: relative; display: flex; align-items: center; min-height: calc(100vh - 60px); padding: 24px 0; }
  .grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: 52px; align-items: center; width: 100%; }

  .scroll-cue { position: absolute; left: 50%; bottom: 26px; transform: translateX(-50%);
    display: inline-flex; flex-direction: column; align-items: center; gap: 2px;
    color: var(--muted); font-size: 12px; letter-spacing: .1em; animation: cue 1.8s ease-in-out infinite; }
  .scroll-cue:hover { color: var(--fg); }
  @keyframes cue { 0%, 100% { transform: translate(-50%, 0); } 50% { transform: translate(-50%, 5px); } }

  .hand { margin: 0; }
  .hand .zh { font-family: var(--hand-zh); font-size: clamp(48px, 7vw, 92px); line-height: 1.2; color: var(--fg); letter-spacing: 2px; }
  .sub { color: var(--text); font-size: clamp(15px, 1.5vw, 18px); margin: 28px 0 0; max-width: 30em; }
  .cta-row { display: flex; gap: 14px; align-items: center; margin-top: 30px; flex-wrap: wrap; }
  .btn { background: var(--btn); color: var(--btn-fg); padding: 13px 30px; border-radius: 999px; font-weight: 700; font-size: 16px; }
  .btn:hover { filter: brightness(1.06); }
  .ghost { padding: 13px 26px; border-radius: 999px; border: 1px solid var(--hairline); color: var(--fg); font-weight: 600; }
  .ghost:hover { background: color-mix(in srgb, var(--fg) 5%, transparent); }

  @media (max-width: 880px) {
    .grid { grid-template-columns: 1fr; gap: 36px; }
    .editor-wrap { order: 2; }
    .hero { padding: 40px 0; min-height: 0; }
  }
</style>
