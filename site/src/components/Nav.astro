---
import { t, type Locale } from '@/i18n';
import { withBase } from '@/lib/url';
const { locale } = Astro.props as { locale: Locale };
const isEn = locale === 'en';
const home = withBase(isEn ? '/en/' : '/');
// 功能/下载 are sections on the HOME page, so link to home + hash (works from any page).
const features = home + '#features';
const download = home + '#download';
// Trailing slash matters: GitHub Pages 301-redirects `/docs` → `/docs/` and DROPS the
// hash, so `/docs#/zh/faq` lands on the default doc. Link the canonical `/docs/` directly.
const docs = withBase('/docs/') + (isEn ? '#/en/getting-started' : '');
const faq = withBase('/docs/') + (isEn ? '#/en/faq' : '#/zh/faq');
const timeline = withBase(isEn ? '/en/timeline/' : '/timeline/');
// Which page is current → its nav item shows a filled "pill".
const baseUrl = import.meta.env.BASE_URL;
const rel = Astro.url.pathname.slice(baseUrl.length).replace(/^\//, '').replace(/\/$/, '');
const page = rel.replace(/^en\/?/, '') || 'home'; // 'home' | 'docs' | 'timeline'
const links = [
  { key: 'home', href: home, label: t(locale, 'nav.home') },
  { key: 'features', href: features, label: t(locale, 'nav.features') },
  { key: 'download', href: download, label: t(locale, 'nav.download') },
  { key: 'docs', href: docs, label: t(locale, 'nav.docs') },
  { key: 'timeline', href: timeline, label: t(locale, 'nav.timeline') },
  { key: 'faq', href: faq, label: t(locale, 'nav.faq') },
];
const other = withBase(isEn ? '/' : '/en');
---
<nav class="nav">
  <div class="container">
   <div class="nav-inner">
    <a class="brand" href={home} aria-label="Mox">
      <span class="badge" id="nav-mo" aria-hidden="true"></span><span class="word">Mox</span>
    </a>

    <div class="links">
      {links.map((l) => (
        <a href={l.href} class:list={{ active: l.key === page }}>{l.label}</a>
      ))}
    </div>

    <div class="right">
      <a class="lang" href={other} aria-label={isEn ? 'Switch to Chinese' : '切换到英文'}>
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.6 2.6 2.6 15.4 0 18M12 3c-2.6 2.6-2.6 15.4 0 18"/></svg>
        <span>{isEn ? 'EN' : '中文'}</span>
      </a>
      <button id="theme-open" class="theme-btn" aria-label={t(locale, 'nav.themes')}>
        <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M12 3a9 9 0 0 0 0 18c.83 0 1.5-.67 1.5-1.5 0-.39-.15-.74-.39-1-.24-.27-.39-.62-.39-1 0-.83.67-1.5 1.5-1.5H16a5 5 0 0 0 5-5c0-4.42-4.03-8-9-8m-5.5 9a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m3-4a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m3 4a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3"/></svg>
        <span>{t(locale, 'nav.themes')}</span>
      </button>
    </div>
   </div>
  </div>
</nav>
<style>
  /* Floating capsule bar (zditor-style). */
  .nav { position: sticky; top: 0; z-index: 50; padding: 12px 0; }
  .nav-inner { display: flex; align-items: center; gap: 28px; height: 56px; width: 100%; padding: 0 8px 0 16px;
    border-radius: 999px; background: color-mix(in srgb, var(--card) 86%, transparent);
    backdrop-filter: blur(14px); border: 1px solid var(--hairline); box-shadow: 0 8px 28px rgba(0,0,0,.12); }
  .brand { display: flex; align-items: center; gap: 10px; font-weight: 800; font-size: 18px; color: var(--fg); }
  /* Brand mark: fixed espresso badge holding the animated 墨 (kept stable across themes). */
  .badge { display: grid; place-items: center; width: 32px; height: 32px; border-radius: 9px;
           background: #463524; }
  .badge :global(svg) { width: 26px; height: 26px; }

  .links { display: flex; align-items: center; gap: 4px; font-size: 15px; font-weight: 500; }
  .links a { padding: 8px 15px; border-radius: 999px; color: var(--muted); white-space: nowrap; transition: background .15s ease, color .15s ease; }
  .links a:hover { color: var(--fg); background: color-mix(in srgb, var(--fg) 6%, transparent); }
  .links a.active { background: var(--fg); color: var(--bg); font-weight: 600; }

  .right { margin-left: auto; display: flex; align-items: center; gap: 10px; }
  .lang, .theme-btn { display: inline-flex; align-items: center; gap: 7px; padding: 8px 14px; border-radius: 999px;
    border: 1px solid var(--hairline); color: var(--fg); font-size: 14px; font-weight: 600;
    background: none; cursor: pointer; font-family: inherit; }
  .lang:hover, .theme-btn:hover { background: color-mix(in srgb, var(--fg) 6%, transparent); }
  .lang svg, .theme-btn svg { color: var(--muted); }

  @media (max-width: 820px) {
    .links { display: none; }
    .lang span, .theme-btn span { display: none; }
    .lang, .theme-btn { padding: 8px; }
  }
</style>

<script>
  import HanziWriter from 'hanzi-writer';
  import moData from '@/data/mo-char.json';

  let moTimer: number | undefined;
  function setupNavInk() {
    const target = document.getElementById('nav-mo');
    if (!target || target.dataset.inked) return; // nav is re-rendered per page; guard re-init
    target.dataset.inked = '1';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const writer = HanziWriter.create(target, '墨', {
      width: 26, height: 26, padding: 1,
      showOutline: false, showCharacter: false,
      strokeColor: '#f3ead8', strokeAnimationSpeed: 2.4, delayBetweenStrokes: 40,
      charDataLoader: (_c: string, onComplete: (d: unknown) => void) => onComplete(moData),
    });
    writer.showCharacter();      // always visible immediately (no blank badge)
    if (!reduce) {
      setTimeout(() => writer.animateCharacter(), 600);
      if (moTimer) clearInterval(moTimer);
      moTimer = window.setInterval(() => writer.animateCharacter(), 9000);
    }
  }
  document.addEventListener('astro:page-load', setupNavInk);
</script>

