---
import { t, type Locale } from '@/i18n';
const { locale } = Astro.props as { locale: Locale };
const home = locale === 'en' ? '/en' : '/';
const other = locale === 'en' ? '/' : '/en';
---
<nav class="nav">
  <div class="container nav-inner">
    <a class="brand" href={home}>墨 Mox</a>
    <div class="links">
      <a href="#features">{t(locale, 'nav.features')}</a>
      <a href="#themes">{t(locale, 'nav.themes')}</a>
      <a href="/docs">{t(locale, 'nav.docs')}</a>
      <a class="lang" href={other}>{locale === 'en' ? '中' : 'EN'}</a>
      <a class="dl" href="https://github.com/Leejaywell/Mox/releases/latest">{t(locale, 'nav.download')}</a>
    </div>
  </div>
</nav>
<style>
  .nav { position: sticky; top: 0; z-index: 50; backdrop-filter: blur(12px);
         background: color-mix(in srgb, var(--bg) 72%, transparent);
         border-bottom: 1px solid var(--hairline); }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 56px; }
  .brand { font-weight: 700; font-size: 18px; letter-spacing: .3px; }
  .links { display: flex; align-items: center; gap: 20px; color: var(--muted); font-size: 14px; }
  .links a:hover { color: var(--fg); }
  .lang { border: 1px solid var(--hairline); border-radius: 6px; padding: 3px 9px; line-height: 1; }
  .dl { background: var(--accent); color: #fff; padding: 7px 15px; border-radius: 8px; font-weight: 500; }
  .dl:hover { filter: brightness(1.08); color: #fff; }
  @media (max-width: 640px) {
    .links { gap: 12px; font-size: 13px; }
    .links a:not(.dl):not(.lang) { display: none; }
  }
</style>
