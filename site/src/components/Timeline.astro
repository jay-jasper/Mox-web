---
import type { Locale } from '@/i18n';
const { locale } = Astro.props as { locale: Locale };
const L = (zh: string, en: string) => (locale === 'en' ? en : zh);

interface Entry { date: string; t: string; d: string; }
// Curated from the project's commit history (2026-05-28 → present), newest first.
const entries: Entry[] = [
  { date: '2026-06-23', t: L('速记增强', 'Quick Notes, refined'),
    d: L('钉在屏幕、居中生成、贴边握柄、管理面板删除，以及菜单栏速记列表。', 'Pin to screen, centered spawn, edge handle, delete from the manager, and a menu-bar notes list.') },
  { date: '2026-06-22', t: L('速记上线 · 菜单栏常驻', 'Quick Notes · resident menu bar'),
    d: L('浮动便签、存到桌面、停靠抽屉、全局快捷键 ⌥⌘N、便签管理器；关窗后退居菜单栏常驻。', 'Floating notes, save-to-Desktop, edge-dock, the ⌥⌘N hotkey, a manager — and the app stays resident in the menu bar after the window closes.') },
  { date: '2026-06-22', t: L('导出详细设置', 'Rich export settings'),
    d: L('分格式的导出设置面板、导出时即时覆盖与实时预览。', 'Per-format export panels with on-the-fly overrides and live preview.') },
  { date: '2026-06-21', t: L('内联嵌入编辑 · 简历工坊重做', 'Inline embeds · Resume Studio rework'),
    d: L('行内嵌入源码编辑，简历工坊重做，设置与主题打磨。', 'Edit embedded blocks inline, a reworked Resume Studio, and settings/theme polish.') },
  { date: '2026-06-20', t: L('编辑器大跃进', 'Editor leap'),
    d: L('命令面板、斜杠菜单分组、强调色预设、设置/面板动画与排版层级。', 'Command palette, grouped slash menu, accent presets, animated panels and tighter hierarchy.') },
  { date: '2026-06-19', t: L('查找替换 · 表格 · 导入导出', 'Find/replace · tables · import-export'),
    d: L('查找替换、表格增强、Markdown 导入导出，知识图谱新增节点类型。', 'Find & replace, richer tables, Markdown import/export, and new knowledge-graph node kinds.') },
  { date: '2026-06-18', t: L('自包含数学 · AI 补全', 'Self-contained math · AI completion'),
    d: L('公式渲染为图、离线自足；富文本复制、正则查找、AI 幽灵补全。', 'Math rendered to images and fully offline; copy as rich text, regex find, and AI ghost completion.') },
  { date: '2026-06-17', t: L('折叠 · 拖拽重排 · 上下标', 'Folding · drag-reorder · sub/superscript'),
    d: L('可折叠标题、块拖拽重排、上下标，以及斜杠菜单里的 AI 动作。', 'Collapsible headings, drag-to-reorder blocks, super/subscript, and AI actions in the slash menu.') },
  { date: '2026-06-11', t: L('完整菜单体系 · 思维导图画布', 'Full menus · mind-map canvas'),
    d: L('成体系的文件/编辑/段落/格式/帮助菜单，Markdown 一键转 Excalidraw 思维导图，知识图谱以标签页打开，「墨」书写动画与双语内置帮助。', 'A complete menu system, one-click Markdown → Excalidraw mind-map, the knowledge graph as a tab, the 墨 writing animation, and bilingual built-in help.') },
  { date: '2026-06-10', t: L('全元素即时转换', 'Everything converts live'),
    d: L('[[wiki]]、链接、$公式$ 等随输入实时转换；预览/沉浸模式、源码语法高亮、可重绑定的快捷键体系。', 'Wiki links, autolinks and $math$ convert as you type; read-only preview & immersive modes, source-pane highlighting, and a rebindable shortcut system.') },
  { date: '2026-06-05', t: L('图片粘贴 · 网页转 Markdown', 'Image paste · web-to-Markdown'),
    d: L('粘贴/拖拽图片自动上传插入，网页内容粘贴转 Markdown，分屏双向同步滚动。', 'Paste/drag images to upload and insert, paste web content as Markdown, two-way synced split scrolling.') },
  { date: '2026-06-04', t: L('内联编辑 · 脚注 · 缩放', 'Inline editing · footnotes · resize'),
    d: L('表格、公式、图表单击就地编辑，可点击的脚注，拖拽缩放图片与公式。', 'Single-click inline editing for tables, math and diagrams; clickable footnotes; drag-resize images and formulas.') },
  { date: '2026-06-03', t: L('所见即所得成型', 'WYSIWYG takes shape'),
    d: L('警告框、可编辑代码块、表格可视化编辑、行内嵌入源码编辑，源码模式与分屏预览到位。', 'Callouts, editable code blocks, a visual table editor, inline embed-source editing, plus source mode and split preview.') },
  { date: '2026-06-01', t: L('重写为纯原生 Swift 引擎', 'Rebuilt on a native Swift engine'),
    d: L('解析、渲染、导出、搜索、知识图谱、AI 全部原生化（MoxKit），整套界面与功能分阶段还原。', 'Parsing, rendering, export, search, knowledge graph and AI all go native (MoxKit); the whole UI is restored in phases.') },
  { date: '2026-05-31', t: L('主题与动态特效首发', 'Themes & ambient effects debut'),
    d: L('多套主题与强调色、四种动态背景，全局命令中心 ⇧⌘P、PDF 双栏研读、Excalidraw 画布、反向链接与今日笔记。', 'Multiple themes and accents, four ambient effects, the ⇧⌘P command palette, dual-pane PDF reading, an Excalidraw canvas, backlinks and daily notes.') },
  { date: '2026-05-30', t: L('即输即见的富文本编辑', 'Instant rich-text editing'),
    d: L('实时渲染、离线代码高亮、原生窗口外壳与完整菜单栏。', 'Live rendering, offline syntax highlighting, native chrome and a full menu bar.') },
  { date: '2026-05-28', t: L('项目启动', 'Project begins'),
    d: L('Mox 内核成型：Markdown 解析、文档模型、工作区文件树、撤销重做、全文搜索，以及第一个 macOS 编辑器。', 'The Mox core takes shape: Markdown parsing, document model, workspace file tree, undo/redo, full-text search, and the first macOS editor.') },
];
---
<section class="tl">
  <div class="container">
    <h1 class="tl-title">{L('时间线', 'Timeline')}</h1>
    <p class="tl-sub">{L('Mox 的成长，按提交历史一路记录。', "Mox's growth, traced through its commit history.")}</p>

    <ol class="line">
      {entries.map((e) => (
        <li class="node" data-reveal>
          <div class="dot"></div>
          <time class="date">{e.date}</time>
          <h3 class="t">{e.t}</h3>
          <p class="d">{e.d}</p>
        </li>
      ))}
    </ol>

    <p class="tl-foot">{L('持续打磨中 —— 敬请期待更多更新。', 'Still evolving — more to come.')}</p>
  </div>
</section>

<style>
  .tl { padding: 64px 0 96px; }
  .tl-title { font-size: clamp(32px, 5vw, 52px); margin: 0 0 8px; }
  .tl-sub { color: var(--muted); margin: 0 0 48px; }
  .line { list-style: none; margin: 0; padding: 0; position: relative; max-width: 720px; }
  .line::before { content: ""; position: absolute; left: 7px; top: 6px; bottom: 6px; width: 2px;
    background: linear-gradient(var(--accent), color-mix(in srgb, var(--accent) 20%, transparent)); }
  .node { position: relative; padding: 0 0 32px 36px; }
  .dot { position: absolute; left: 0; top: 4px; width: 16px; height: 16px; border-radius: 50%;
    background: var(--bg); border: 3px solid var(--accent); box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 18%, transparent); }
  .date { font-size: 13px; font-weight: 600; color: var(--accent); letter-spacing: .04em; }
  .node .t { font-size: 19px; margin: 6px 0 6px; }
  .node .d { color: var(--text); margin: 0; line-height: 1.7; }
  .tl-foot { color: var(--muted); margin-top: 12px; }
  .tl-foot a { color: var(--accent); }
</style>
